{
  "private": true,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "prod": "npm run production",
    "production": "mix --production",
    "nova:install": "cd vendor/laravel/nova-devtool && npm install",
    "lint": "./vendor/bin/duster lint",
    "lint:fix": "./vendor/bin/duster fix",
    "refactor": "./vendor/bin/rector process --dry-run",
    "refactor:apply": "./vendor/bin/rector process",
    "analyse": "./vendor/bin/phpstan analyse --memory-limit=512M",
    "analyse:report": "./vendor/bin/phpstan analyse --memory-limit=512M --error-format=json > phpstan-report.json || true",
    "test": "./vendor/bin/pest --testsuite=Unit,Feature",
    "test:unit": "./vendor/bin/pest --testsuite=Unit",
    "test:feature": "./vendor/bin/pest --testsuite=Feature",
    "test:web": "./vendor/bin/pest -c phpunit.dusk.xml",
    "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/pest --testsuite=Unit,Feature --coverage --min=80",
    "release:dry": "npx semantic-release --dry-run --no-ci",
    "quality": "npm run lint && npm run analyse && npm run test",
    "check": "npm run lint:fix && npm run refactor:apply && npm run lint && npm run analyse && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "laravel-nova-devtool": "file:vendor/laravel/nova-devtool",
    "lint-staged": "^16.4.0",
    "lodash": "^4.17.21",
    "semantic-release": "^24.2.9"
  },
  "dependencies": {
    "@turf/circle": "^7.1.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "leaflet-routing-machine": "^3.2.12"
  }
}
